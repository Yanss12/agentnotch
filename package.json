{
  "name": "agentnotch",
  "version": "0.1.0",
  "description": "Dynamic-island style desktop widget for Claude agents",
  "author": { "name": "AgentNotch", "email": "noreply@agentnotch.app" },
  "homepage": "https://github.com/Mystic0112/Agentnotch",
  "repository": { "type": "git", "url": "https://github.com/Mystic0112/Agentnotch.git" },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder -mwl",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "release": "electron-builder -mwl --publish always"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.agentnotch.app",
    "productName": "AgentNotch",
    "asar": true,
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "icon.png",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ]
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64", "arm64"] },
        { "target": "deb", "arch": ["x64", "arm64"] }
      ],
      "category": "Utility"
    },
    "publish": [
      { "provider": "github", "owner": "Mystic0112", "repo": "Agentnotch" }
    ]
  }
}
