{
  "name": "agentnotch",
  "version": "0.1.7",
  "description": "Dynamic-island style desktop widget for Claude agents",
  "author": {
    "name": "AgentNotch",
    "email": "noreply@agentnotch.app"
  },
  "homepage": "https://github.com/Yanss12/agentnotch",
  "repository": {
    "type": "git",
    "url": "https://github.com/Yanss12/agentnotch.git"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder -mwl",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "release": "electron-builder -mwl --publish always"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.agentnotch.app",
    "productName": "AgentNotch",
    "asar": true,
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "icon.png",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "Utility"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Yanss12",
        "repo": "agentnotch",
        "releaseType": "release"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
